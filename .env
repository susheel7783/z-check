# Z-Check Environment Variables

# Alert Mode Configuration
# Set to LOG_ONLY for testing without sending actual WhatsApp messages
# Set to PRODUCTION to send real WhatsApp alerts
ALERT_MODE=LOG_ONLY

# Runtime and production configuration
GIN_MODE=release
VITE_API_URL=http://localhost:8080

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Neo4j Configuration
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# WhatsApp Alerting Configuration (IMPORTANT: Set these for alerts to work)
# 
# OPTION 1: Twilio WhatsApp (Recommended for testing - Free trial)
# ============================================================
# 1. Sign up at https://www.twilio.com/console (no credit card needed for trial)
# 2. Go to Messaging → Services → Create new service
# 3. Select WhatsApp integration
# 4. Add phone: +918765290618
# 5. Confirm verification code Twilio sends you
# 6. Copy Account SID and Auth Token from dashboard
# 7. Set these variables:
# WHATSAPP_API_URL=https://api.twilio.com/2010-04-01/Accounts/{YOUR_ACCOUNT_SID}/Messages.json
# WHATSAPP_API_TOKEN={YOUR_AUTH_TOKEN}
# ALERT_WHATSAPP_TO=+918765290618
#
# OPTION 2: Meta WhatsApp Business API (Production use)
# ====================================================
# 1. Go to https://business.facebook.com
# 2. Create Meta Business Account
# 3. Set up WhatsApp Business Account
# 4. Get Phone Number ID and User Access Token
# 5. Set these variables:
# WHATSAPP_API_URL=https://graph.facebook.com/v18.0/{YOUR_PHONE_NUMBER_ID}/messages
# WHATSAPP_API_TOKEN={YOUR_USER_ACCESS_TOKEN}
# ALERT_WHATSAPP_TO=+918765290618  # E.164 format required for Meta Graph API
#
# NOTE: Leave empty to skip WhatsApp alerts and see logs instead

WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
ALERT_WHATSAPP_TO=+918765290618

# Email alerting configuration
# Set these variables if you want Z-Check to send alert email notifications.
### Set ALERT_MODE=EMAIL_ONLY to send only email alerts and skip WhatsApp.
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
ALERT_EMAIL_FROM=alerts@zcheck.local
ALERT_EMAIL_TO=

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8080

# GCP/GKE Deployment (optional)
# Uncomment and configure for cloud deployment:
# GKE_CLUSTER_NAME=my-cluster
# GKE_ZONE=us-central1-a
