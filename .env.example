# Z-Check Environment Variables
# Copy this file to .env and fill in your actual values

# Neo4j Configuration
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_secure_password_here

# WhatsApp Alerting (optional, leave empty to disable)
# To use WhatsApp alerts:
# 1. Get PHONE_NUMBER_ID from your WhatsApp Business Account
# 2. Get an API token from Meta Business Platform
WHATSAPP_API_URL=https://graph.facebook.com/v16.0/PHONE_NUMBER_ID/messages
WHATSAPP_API_TOKEN=your_whatsapp_token_here
ALERT_WHATSAPP_TO=+1234567890

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8080

# GCP/GKE Deployment (optional)
# Uncomment and configure for cloud deployment:
# REACT_APP_API_URL=https://z-check.example.com/api
# NEO4J_URI=neo4j://neo4j.example.com:7687
